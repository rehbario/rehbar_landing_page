# Supabase — waitlist storage (SERVER-ONLY; never exposed to the browser).
# Supabase dashboard → Project Settings → API.
# The service role key bypasses Row Level Security — keep it secret, set it only
# in .env.local (gitignored) and in your host's env vars (e.g. Vercel).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
